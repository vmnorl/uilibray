            Display.BackgroundTransparency = 0
            MainCP.MainPoint.ImageTransparency = 1
            MainCP.Image = "http://www.roblox.com/asset/?id=11415645739"
            MainCP.ImageTransparency = 1
            Background.BackgroundTransparency = 1
            ColorPicker.Interact.Size = UDim2.new(1,0,1,0)
            ColorPicker.Interact.Position = UDim2.new(0.5,0,0.5,0)

            local opened = false
            local mouse = Players.LocalPlayer:GetMouse()
            local mainDragging = false
            local sliderDragging = false
            local h, s, v = ColorPickerSettings.Color:ToHSV()

            local function setDisplay()
                MainCP.MainPoint.Position = UDim2.new(s, -MainCP.MainPoint.AbsoluteSize.X/2, 1-v, -MainCP.MainPoint.AbsoluteSize.Y/2)
                MainCP.MainPoint.ImageColor3 = Color3.fromHSV(h,s,v)
                Background.BackgroundColor3 = Color3.fromHSV(h,1,1)
                Display.BackgroundColor3 = Color3.fromHSV(h,s,v)
                local x = h * SliderCP.AbsoluteSize.X
                SliderCP.SliderPoint.Position = UDim2.new(0, x - SliderCP.SliderPoint.AbsoluteSize.X/2, 0.5, 0)
                SliderCP.SliderPoint.ImageColor3 = Color3.fromHSV(h,1,1)
                local color = Color3.fromHSV(h,s,v)
                local r,g,b = math.floor(color.R*255+0.5), math.floor(color.G*255+0.5), math.floor(color.B*255+0.5)
                ColorPicker.RGB.RInput.InputBox.Text = tostring(r)
                ColorPicker.RGB.GInput.InputBox.Text = tostring(g)
                ColorPicker.RGB.BInput.InputBox.Text = tostring(b)
                ColorPicker.HexInput.InputBox.Text = string.format("#%02X%02X%02X", color.R*0xFF, color.G*0xFF, color.B*0xFF)
            end
            setDisplay()

            ColorPicker.Interact.MouseButton1Down:Connect(function()
                if not opened then
                    opened = true
                    TweenService:Create(ColorPicker, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {Size = UDim2.new(1,-10,0.224,40)}):Play()
                    TweenService:Create(Background, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {Size = UDim2.new(0,173,0,86), BackgroundTransparency = 0}):Play()
                    TweenService:Create(MainCP, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {ImageTransparency = 0.1}):Play()
                    TweenService:Create(MainCP.MainPoint, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {ImageTransparency = 0}):Play()
                else
                    opened = false
                    TweenService:Create(ColorPicker, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {Size = UDim2.new(1,-10,0.028,35)}):Play()
                    TweenService:Create(Background, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {Size = UDim2.new(0,39,0,22), BackgroundTransparency = 1}):Play()
                    TweenService:Create(MainCP, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {ImageTransparency = 1}):Play()
                    TweenService:Create(MainCP.MainPoint, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {ImageTransparency = 1}):Play()
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    mainDragging = false sliderDragging = false
                end
            end)
            MainCP.MouseButton1Down:Connect(function() if opened then mainDragging = true end end)
            MainCP.MainPoint.MouseButton1Down:Connect(function() if opened then mainDragging = true end end)
            SliderCP.MouseButton1Down:Connect(function() sliderDragging = true end)

            RunService.RenderStepped:Connect(function()
                if mainDragging then
                    s = math.clamp((mouse.X - MainCP.AbsolutePosition.X) / MainCP.AbsoluteSize.X, 0, 1)
                    v = 1 - math.clamp((mouse.Y - MainCP.AbsolutePosition.Y) / MainCP.AbsoluteSize.Y, 0, 1)
                    setDisplay()
                    pcall(function() ColorPickerSettings.Callback(Color3.fromHSV(h,s,v)) end)
                    ColorPickerSettings.Color = Color3.fromHSV(h,s,v)
                    SaveConfiguration()
                end
                if sliderDragging then
                    h = math.clamp((mouse.X - SliderCP.AbsolutePosition.X) / SliderCP.AbsoluteSize.X, 0, 1)
                    setDisplay()
                    pcall(function() ColorPickerSettings.Callback(Color3.fromHSV(h,s,v)) end)
                    ColorPickerSettings.Color = Color3.fromHSV(h,s,v)
                    SaveConfiguration()
                end
            end)

            function ColorPickerSettings:Set(RGBColor)
                ColorPickerSettings.Color = RGBColor
                h, s, v = RGBColor:ToHSV()
                setDisplay()
            end

            if Settings.ConfigurationSaving and Settings.ConfigurationSaving.Enabled and ColorPickerSettings.Flag then
                RayfieldLibrary.Flags[ColorPickerSettings.Flag] = ColorPickerSettings
            end
            return ColorPickerSettings
        end

        return Tab
    end

    -- ════════════════════════════════════════════════════════════════════════
    -- BUILT-IN SETTINGS TAB
    -- ════════════════════════════════════════════════════════════════════════

    task.delay(0.5, function()
        local SettingsTab = Window:CreateTab("⚙️ Settings", nil)

        SettingsTab:CreateSection("Theme")

        SettingsTab:CreateDropdown({
            Name = "Select Theme",
            Options = {"Default", "Light", "Midnight", "Blood"},
            CurrentOption = {initialTheme},
            MultipleOptions = false,
            Flag = "SelectedTheme",
            Callback = function(opts)
                local themeName = opts[1]
                if RayfieldLibrary.Theme[themeName] then
                    ChangeTheme(themeName)
                    RayfieldLibrary:Notify({
                        Title = "Theme Changed",
                        Content = "Applied: " .. themeName,
                        Duration = 2,
                    })
                end
            end,
        })

        SettingsTab:CreateSection("HUD")

        SettingsTab:CreateToggle({
            Name = "Show FPS/Ping HUD",
            CurrentValue = true,
            Flag = "HUDEnabled",
            Callback = function(val)
                HUDConfig.Enabled = val
                if val then
                    createHUD()
                else
                    if HUDGui then HUDGui:Destroy() HUDGui = nil end
                end
            end,
        })

        SettingsTab:CreateToggle({
            Name = "Show FPS",
            CurrentValue = true,
            Flag = "HUDShowFPS",
            Callback = function(val)
                HUDConfig.ShowFPS = val
                createHUD()
            end,
        })

        SettingsTab:CreateToggle({
            Name = "Show Ping",
            CurrentValue = true,
            Flag = "HUDShowPing",
            Callback = function(val)
                HUDConfig.ShowPing = val
                createHUD()
            end,
        })

        SettingsTab:CreateDropdown({
            Name = "HUD Position",
            Options = {"TopRight", "TopLeft", "BottomRight", "BottomLeft"},
            CurrentOption = {"TopRight"},
            MultipleOptions = false,
            Flag = "HUDPosition",
            Callback = function(opts)
                HUDConfig.Position = opts[1]
                createHUD()
                RayfieldLibrary:Notify({
                    Title = "HUD",
                    Content = "Position: " .. opts[1],
                    Duration = 2,
                })
            end,
        })

        SettingsTab:CreateSection("Script Info")

        SettingsTab:CreateParagraph({
            Title = "Version Info",
            Content = "Release: " .. Release .. "\nVersion: " .. RayfieldLibrary.Version .. "\nTheme: " .. CurrentThemeName,
        })

        SettingsTab:CreateButton({
            Name = "🔄 Reload HUD",
            Callback = function()
                createHUD()
                RayfieldLibrary:Notify({ Title = "HUD", Content = "Reloaded!", Duration = 2 })
            end,
        })
    end)

    -- ════════════════════════════════════════════════════════════════════════
    -- FINALIZE WINDOW ANIMATION
    -- ════════════════════════════════════════════════════════════════════════

    Elements.Visible = true
    task.wait(0.7)
    TweenService:Create(LoadingFrame.Title, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {TextTransparency = 1}):Play()
    TweenService:Create(LoadingFrame.Subtitle, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {TextTransparency = 1}):Play()
    TweenService:Create(LoadingFrame.Version, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {TextTransparency = 1}):Play()
    task.wait(0.2)
    TweenService:Create(Main, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {Size = UDim2.new(0,500,0,475)}):Play()
    TweenService:Create(Main.Shadow.Image, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {ImageTransparency = 0.4}):Play()

    Topbar.BackgroundTransparency = 1
    Topbar.Divider.Size = UDim2.new(0,0,0,1)
    Topbar.CornerRepair.BackgroundTransparency = 1
    Topbar.Title.TextTransparency = 1
    Topbar.Theme.ImageTransparency = 1
    Topbar.ChangeSize.ImageTransparency = 1
    Topbar.Hide.ImageTransparency = 1

    task.wait(0.5)
    Topbar.Visible = true
    TweenService:Create(Topbar, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {BackgroundTransparency = 0}):Play()
    TweenService:Create(Topbar.CornerRepair, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {BackgroundTransparency = 0}):Play()
    task.wait(0.1)
    TweenService:Create(Topbar.Divider, TweenInfo.new(1, Enum.EasingStyle.Quint), {Size = UDim2.new(1,0,0,1)}):Play()
    task.wait(0.1)
    TweenService:Create(Topbar.Title, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {TextTransparency = 0}):Play()
    task.wait(0.1)
    TweenService:Create(Topbar.Theme, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {ImageTransparency = 0.8}):Play()
    task.wait(0.1)
    TweenService:Create(Topbar.ChangeSize, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {ImageTransparency = 0.8}):Play()
    task.wait(0.1)
    TweenService:Create(Topbar.Hide, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {ImageTransparency = 0.8}):Play()
    task.wait(0.3)

    return Window
end

-- ════════════════════════════════════════════════════════════════════════════════
-- TOPBAR BUTTONS
-- ════════════════════════════════════════════════════════════════════════════════

Topbar.ChangeSize.MouseButton1Click:Connect(function()
    if Debounce then return end
    if Minimised then Minimised = false Maximise()
    else Minimised = true Minimise() end
end)

Topbar.Hide.MouseButton1Click:Connect(function()
    if Debounce then return end
    if Hidden then Hidden = false Unhide()
    else Hidden = true Hide() end
end)

UserInputService.InputBegan:Connect(function(input, processed)
    if input.KeyCode == Enum.KeyCode.K and not processed then
        if Debounce then return end
        if Hidden then Hidden = false Unhide()
        else Hidden = true Hide() end
    end
end)

for _, btn in ipairs(Topbar:GetChildren()) do
    if btn.ClassName == "ImageButton" then
        btn.MouseEnter:Connect(function() TweenService:Create(btn, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {ImageTransparency = 0}):Play() end)
        btn.MouseLeave:Connect(function() TweenService:Create(btn, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {ImageTransparency = 0.8}):Play() end)
        btn.MouseButton1Click:Connect(function() TweenService:Create(btn, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {ImageTransparency = 0.8}):Play() end)
    end
end

-- ════════════════════════════════════════════════════════════════════════════════
-- MISC
-- ════════════════════════════════════════════════════════════════════════════════

function RayfieldLibrary:LoadConfiguration()
    if CEnabled then
        pcall(function()
            if isfile(ConfigurationFolder .. "/" .. CFileName .. ConfigurationExtension) then
                LoadConfiguration(readfile(ConfigurationFolder .. "/" .. CFileName .. ConfigurationExtension))
                RayfieldLibrary:Notify({
                    Title = "Configuration Loaded",
                    Content = "Previous session config restored",
                    Duration = 3,
                })
            end
        end)
    end
end

function RayfieldLibrary:Destroy()
    if HUDGui then HUDGui:Destroy() end
    Rayfield:Destroy()
end

task.delay(3.5, RayfieldLibrary.LoadConfiguration, RayfieldLibrary)

return RayfieldLibrary
