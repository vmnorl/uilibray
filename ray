local function showVersionChooser()
    local chosen = nil

    -- We reuse the Rayfield asset look: dark background, rounded card, divider
    local ChooserGui = Instance.new("ScreenGui")
    ChooserGui.Name = "RayfieldVersionChooser"
    ChooserGui.ResetOnSpawn = false
    ChooserGui.DisplayOrder = 9999
    ChooserGui.IgnoreGuiInset = true

    if gethui then
        ChooserGui.Parent = gethui()
    elseif syn and syn.protect_gui then
        syn.protect_gui(ChooserGui)
        ChooserGui.Parent = CoreGui
    elseif CoreGui:FindFirstChild("RobloxGui") then
        ChooserGui.Parent = CoreGui:FindFirstChild("RobloxGui")
    else
        ChooserGui.Parent = CoreGui
    end

    -- ── Backdrop (same dim overlay Rayfield uses during loading) ────────────
    local Backdrop = Instance.new("Frame")
    Backdrop.Size = UDim2.new(1, 0, 1, 0)
    Backdrop.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    Backdrop.BackgroundTransparency = 0.5
