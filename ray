-- FPS / PING HUD
-- ════════════════════════════════════════════════════════════════════════════════

local HUDConfig = {
    Enabled    = true,
    ShowFPS    = true,
    ShowPing   = true,
    Position   = "TopRight", -- TopRight, TopLeft, BottomRight, BottomLeft
}

local HUDGui = nil

local function createHUD()
    if HUDGui then HUDGui:Destroy() HUDGui = nil end
    if not HUDConfig.Enabled then return end

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "RayfieldHUD"
    screenGui.ResetOnSpawn = false
    screenGui.DisplayOrder = 200
    screenGui.IgnoreGuiInset = true

    if gethui then
        screenGui.Parent = gethui()
    elseif syn and syn.protect_gui then
        syn.protect_gui(screenGui)
        screenGui.Parent = CoreGui
    else
        screenGui.Parent = CoreGui
    end

    -- Anchor position
    local anchorX, anchorY, posX, posY = 1, 0, 1, 0
    if HUDConfig.Position == "TopLeft" then
        anchorX, anchorY, posX, posY = 0, 0, 0, 0
    elseif HUDConfig.Position == "BottomRight" then
        anchorX, anchorY, posX, posY = 1, 1, 1, 1
    elseif HUDConfig.Position == "BottomLeft" then
        anchorX, anchorY, posX, posY = 0, 1, 0, 1
    end

    local frame = Instance.new("Frame")
    frame.Name = "HUDFrame"
    frame.Size = UDim2.new(0, 120, 0, 46)
    frame.AnchorPoint = Vector2.new(anchorX, anchorY)
    frame.Position = UDim2.new(posX, posX == 1 and -8 or 8, posY, posY == 1 and -8 or 36)
    frame.BackgroundColor3 = SelectedTheme.HUDBackground
    frame.BackgroundTransparency = 0.15
    frame.BorderSizePixel = 0
    frame.Parent = screenGui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = frame

    local stroke = Instance.new("UIStroke")
    stroke.Color = SelectedTheme.ElementStroke
    stroke.Thickness = 1
    stroke.Transparency = 0.5
    stroke.Parent = frame

    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Vertical
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Center
    layout.Padding = UDim.new(0, 2)
    layout.Parent = frame

    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 8)
    padding.PaddingRight = UDim.new(0, 8)
    padding.PaddingTop = UDim.new(0, 4)
    padding.PaddingBottom = UDim.new(0, 4)
    padding.Parent = frame

    local fpsLabel, pingLabel

    if HUDConfig.ShowFPS then
        fpsLabel = Instance.new("TextLabel")
        fpsLabel.Name = "FPS"
        fpsLabel.Size = UDim2.new(1, 0, 0, 18)
        fpsLabel.BackgroundTransparency = 1
        fpsLabel.Text = "FPS: --"
        fpsLabel.TextColor3 = SelectedTheme.HUDText
        fpsLabel.TextSize = 13
        fpsLabel.Font = Enum.Font.GothamBold
        fpsLabel.TextXAlignment = Enum.TextXAlignment.Left
        fpsLabel.Parent = frame
    end

    if HUDConfig.ShowPing then
        pingLabel = Instance.new("TextLabel")
        pingLabel.Name = "Ping"
        pingLabel.Size = UDim2.new(1, 0, 0, 18)
        pingLabel.BackgroundTransparency = 1
        pingLabel.Text = "Ping: --ms"
        pingLabel.TextColor3 = SelectedTheme.HUDText
        pingLabel.TextSize = 13
        pingLabel.Font = Enum.Font.GothamBold
        pingLabel.TextXAlignment = Enum.TextXAlignment.Left
        pingLabel.Parent = frame
    end

    -- Adjust frame height
    local count = (HUDConfig.ShowFPS and 1 or 0) + (HUDConfig.ShowPing and 1 or 0)
    frame.Size = UDim2.new(0, 120, 0, 12 + count * 20)

    HUDGui = screenGui

    -- Update loop
    local fpsBuffer = {}
    local lastUpdate = 0

    RunService.Heartbeat:Connect(function(dt)
        if not HUDGui or not HUDGui.Parent then return end

        -- FPS calculation
        table.insert(fpsBuffer, 1 / dt)
        if #fpsBuffer > 30 then table.remove(fpsBuffer, 1) end

        local now = tick()
        if now - lastUpdate < 0.5 then return end
        lastUpdate = now

        if fpsLabel and HUDConfig.ShowFPS then
            local sum = 0
            for _, v in ipairs(fpsBuffer) do sum += v end
            local fps = math.floor(sum / #fpsBuffer)
            local color
            if fps >= 50 then
                color = SelectedTheme.HUDGood
            elseif fps >= 30 then
                color = SelectedTheme.HUDWarn
            else
                color = SelectedTheme.HUDBad
            end
            fpsLabel.Text = "FPS: " .. fps
            fpsLabel.TextColor3 = color
        end

        if pingLabel and HUDConfig.ShowPing then
            local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            local color
            if ping <= 80 then
                color = SelectedTheme.HUDGood
            elseif ping <= 150 then
                color = SelectedTheme.HUDWarn
            else
                color = SelectedTheme.HUDBad
            end
            pingLabel.Text = "Ping: " .. ping .. "ms"
            pingLabel.TextColor3 = color
        end
    end)
end

