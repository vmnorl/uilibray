-- FPS / PING HUD
-- ════════════════════════════════════════════════════════════════════════════════

local HUDConfig = {
    Enabled  = true,
    ShowFPS  = true,
    ShowPing = true,
    Position = "TopRight",
}

local HUDGui = nil

local function createHUD()
    if HUDGui then pcall(function() HUDGui:Destroy() end) HUDGui = nil end
    if not HUDConfig.Enabled then return end

    local sg = Instance.new("ScreenGui")
    sg.Name = "RayfieldHUD"
    sg.ResetOnSpawn = false
    sg.DisplayOrder = 200
    sg.IgnoreGuiInset = true

    if gethui then
        sg.Parent = gethui()
    elseif syn and syn.protect_gui then
        syn.protect_gui(sg)
        sg.Parent = CoreGui
    else
        sg.Parent = CoreGui
    end

    local ax, ay, px, py = 1, 0, 1, 0
    if HUDConfig.Position == "TopLeft"     then ax,ay,px,py = 0,0,0,0
    elseif HUDConfig.Position == "BottomRight" then ax,ay,px,py = 1,1,1,1
    elseif HUDConfig.Position == "BottomLeft"  then ax,ay,px,py = 0,1,0,1
    end

    local count = (HUDConfig.ShowFPS and 1 or 0) + (HUDConfig.ShowPing and 1 or 0)
    local h = 10 + count * 20

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 110, 0, h)
    frame.AnchorPoint = Vector2.new(ax, ay)
    frame.Position = UDim2.new(px, px == 1 and -8 or 8, py, py == 1 and -8 or 36)
    frame.BackgroundColor3 = SelectedTheme.HUDBackground
    frame.BackgroundTransparency = 0.1
    frame.BorderSizePixel = 0
    frame.Parent = sg

    local fc = Instance.new("UICorner")
    fc.CornerRadius = UDim.new(0, 6)
    fc.Parent = frame

    local fs = Instance.new("UIStroke")
    fs.Color = SelectedTheme.ElementStroke
    fs.Thickness = 1
    fs.Transparency = 0.5
    fs.Parent = frame

    local fl = Instance.new("UIListLayout")
    fl.FillDirection = Enum.FillDirection.Vertical
    fl.HorizontalAlignment = Enum.HorizontalAlignment.Center
    fl.VerticalAlignment = Enum.VerticalAlignment.Center
    fl.Padding = UDim.new(0, 2)
    fl.Parent = frame

    local fp = Instance.new("UIPadding")
    fp.PaddingLeft = UDim.new(0, 7)
    fp.PaddingRight = UDim.new(0, 7)
    fp.PaddingTop = UDim.new(0, 4)
    fp.PaddingBottom = UDim.new(0, 4)
    fp.Parent = frame

    local fpsLabel, pingLabel

    if HUDConfig.ShowFPS then
        fpsLabel = Instance.new("TextLabel")
        fpsLabel.Size = UDim2.new(1, 0, 0, 16)
        fpsLabel.BackgroundTransparency = 1
        fpsLabel.Text = "FPS: --"
        fpsLabel.TextColor3 = SelectedTheme.HUDText
        fpsLabel.TextSize = 12
        fpsLabel.Font = Enum.Font.GothamBold
        fpsLabel.TextXAlignment = Enum.TextXAlignment.Left
        fpsLabel.Parent = frame
    end

    if HUDConfig.ShowPing then
        pingLabel = Instance.new("TextLabel")
        pingLabel.Size = UDim2.new(1, 0, 0, 16)
        pingLabel.BackgroundTransparency = 1
        pingLabel.Text = "Ping: --ms"
        pingLabel.TextColor3 = SelectedTheme.HUDText
        pingLabel.TextSize = 12
        pingLabel.Font = Enum.Font.GothamBold
        pingLabel.TextXAlignment = Enum.TextXAlignment.Left
        pingLabel.Parent = frame
    end

    HUDGui = sg

    local fpsBuffer = {}
    local lastUpdate = 0

    RunService.Heartbeat:Connect(function(dt)
        if not HUDGui or not HUDGui.Parent then return end

        table.insert(fpsBuffer, 1 / math.max(dt, 0.001))
        if #fpsBuffer > 30 then table.remove(fpsBuffer, 1) end

        local now = tick()
        if now - lastUpdate < 0.5 then return end
        lastUpdate = now

        if fpsLabel and HUDConfig.ShowFPS then
            local sum = 0
            for _, v in ipairs(fpsBuffer) do sum += v end
            local fps = math.floor(sum / #fpsBuffer)
            fpsLabel.Text = "FPS: " .. fps
            fpsLabel.TextColor3 = fps >= 50 and SelectedTheme.HUDGood
                or fps >= 30 and SelectedTheme.HUDWarn
                or SelectedTheme.HUDBad
        end

        if pingLabel and HUDConfig.ShowPing then
            local ok, ping = pcall(function()
                return math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            end)
            if ok then
                pingLabel.Text = "Ping: " .. ping .. "ms"
                pingLabel.TextColor3 = ping <= 80 and SelectedTheme.HUDGood
                    or ping <= 150 and SelectedTheme.HUDWarn
                    or SelectedTheme.HUDBad
            end
        end
    end)
end

