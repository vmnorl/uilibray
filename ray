    -- ── Version buttons (styled exactly like Rayfield element frames) ────────
    local function makeVersionButton(xOffset, labelText, descText, accentColor, badgeText)
        -- Outer frame = Rayfield element style
        local Btn = Instance.new("TextButton")
        Btn.Name = labelText
        Btn.Size = UDim2.new(0, 210, 0, 145)
        Btn.Position = UDim2.new(0, xOffset, 0, 85)
        Btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        Btn.BorderSizePixel = 0
        Btn.Text = ""
        Btn.AutoButtonColor = false
        Btn.BackgroundTransparency = 1
        Btn.ZIndex = 3
        Btn.Parent = Card

        local BtnCorner = Instance.new("UICorner")
        BtnCorner.CornerRadius = UDim.new(0, 5)
        BtnCorner.Parent = Btn

        local BtnStroke = Instance.new("UIStroke")
        BtnStroke.Color = Color3.fromRGB(50, 50, 50)
        BtnStroke.Thickness = 1
        BtnStroke.Transparency = 1
        BtnStroke.Parent = Btn

        -- Accent line at top (like the ElementIndicator arrow in Rayfield buttons)
        local AccentLine = Instance.new("Frame")
        AccentLine.Size = UDim2.new(1, 0, 0, 3)
        AccentLine.Position = UDim2.new(0, 0, 0, 0)
        AccentLine.BackgroundColor3 = accentColor
        AccentLine.BorderSizePixel = 0
        AccentLine.ZIndex = 4
        AccentLine.Parent = Btn

        local AccentCorner = Instance.new("UICorner")
        AccentCorner.CornerRadius = UDim.new(0, 5)
        AccentCorner.Parent = AccentLine

        -- Fix bottom corners of accent line
        local AccentFix = Instance.new("Frame")
        AccentFix.Size = UDim2.new(1, 0, 0.6, 0)
        AccentFix.Position = UDim2.new(0, 0, 0.4, 0)
        AccentFix.BackgroundColor3 = accentColor
        AccentFix.BorderSizePixel = 0
        AccentFix.ZIndex = 4
        AccentFix.Parent = AccentLine

        -- Badge (top right corner, like a tag)
        local Badge = Instance.new("TextLabel")
        Badge.Size = UDim2.new(0, 0, 0, 18)
        Badge.AutomaticSize = Enum.AutomaticSize.X
        Badge.Position = UDim2.new(1, -8, 0, 10)
        Badge.AnchorPoint = Vector2.new(1, 0)
        Badge.BackgroundColor3 = accentColor
        Badge.BackgroundTransparency = 0.3
        Badge.Text = " " .. badgeText .. " "
        Badge.TextColor3 = Color3.fromRGB(255, 255, 255)
        Badge.TextSize = 10
        Badge.Font = Enum.Font.GothamBold
        Badge.BorderSizePixel = 0
        Badge.ZIndex = 5
        Badge.Parent = Btn

        local BadgeCorner = Instance.new("UICorner")
        BadgeCorner.CornerRadius = UDim.new(0, 4)
        BadgeCorner.Parent = Badge

        -- Version name (big title)
        local NameLabel = Instance.new("TextLabel")
        NameLabel.Size = UDim2.new(1, -16, 0, 30)
        NameLabel.Position = UDim2.new(0, 8, 0, 35)
        NameLabel.BackgroundTransparency = 1
        NameLabel.Text = labelText
        NameLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
        NameLabel.TextSize = 20
        NameLabel.Font = Enum.Font.GothamBold
        NameLabel.TextXAlignment = Enum.TextXAlignment.Left
        NameLabel.ZIndex = 4
        NameLabel.Parent = Btn

        -- Bullet features list
        local DescLabel = Instance.new("TextLabel")
        DescLabel.Size = UDim2.new(1, -16, 0, 70)
        DescLabel.Position = UDim2.new(0, 8, 0, 68)
        DescLabel.BackgroundTransparency = 1
        DescLabel.Text = descText
        DescLabel.TextColor3 = Color3.fromRGB(160, 160, 160)
        DescLabel.TextSize = 11
        DescLabel.Font = Enum.Font.Gotham
        DescLabel.TextXAlignment = Enum.TextXAlignment.Left
        DescLabel.TextYAlignment = Enum.TextYAlignment.Top
        DescLabel.TextWrapped = true
        DescLabel.ZIndex = 4
        DescLabel.Parent = Btn

        -- Hover effect
        Btn.MouseEnter:Connect(function()
            TweenService:Create(Btn, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {
                BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            }):Play()
            TweenService:Create(BtnStroke, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {
                Color = accentColor,
                Transparency = 0.5,
            }):Play()
        end)
        Btn.MouseLeave:Connect(function()
            TweenService:Create(Btn, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {
                BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            }):Play()
            TweenService:Create(BtnStroke, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {
                Color = Color3.fromRGB(50, 50, 50),
                Transparency = 1,
            }):Play()
        end)

        Btn.MouseButton1Click:Connect(function()
            -- Flash accent on click
            TweenService:Create(Btn, TweenInfo.new(0.1), {
                BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            }):Play()
            task.wait(0.1)
            chosen = labelText
        end)

        return Btn
    end

    makeVersionButton(
        20,
        "Pro",
        "• All features unlocked\n• ESP, Hitbox, Silent Aim\n• Auto Clicker & Siphon\n• Priority updates",
        Color3.fromRGB(255, 180, 0),
        "FULL"
    )

    makeVersionButton(
        270,
        "Lite",
        "• Lightweight & fast\n• Basic ESP only\n• Reduced features\n• Lower detection risk",
        Color3.fromRGB(100, 180, 255),
        "SAFE"
    )

    -- ── Footer note ──────────────────────────────────────────────────────────
    local FooterNote = Instance.new("TextLabel")
