    FooterNote.Font = Enum.Font.Gotham
    FooterNote.TextXAlignment = Enum.TextXAlignment.Center
    FooterNote.TextTransparency = 1
    FooterNote.ZIndex = 3
    FooterNote.Parent = Card

    -- ── Animate in (same sequence as Rayfield loading) ───────────────────────
    TweenService:Create(Card, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {
        BackgroundTransparency = 0,
        Size = UDim2.new(0, 500, 0, 280),
    }):Play()
    TweenService:Create(ShadowImg, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {
        ImageTransparency = 0.55,
    }):Play()

    task.wait(0.1)
    TweenService:Create(CardTopbar, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {
        BackgroundTransparency = 0,
    }):Play()
    TweenService:Create(CornerRepair, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {
        BackgroundTransparency = 0,
    }):Play()
    task.wait(0.1)
    TweenService:Create(Divider, TweenInfo.new(1, Enum.EasingStyle.Quint), {
        Size = UDim2.new(1, 0, 0, 1),
    }):Play()
    task.wait(0.1)
    TweenService:Create(TopbarTitle, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {
        TextTransparency = 0,
    }):Play()
    task.wait(0.1)
    TweenService:Create(Subtitle, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {
        TextTransparency = 0,
    }):Play()

    -- Animate buttons in
    for _, child in ipairs(Card:GetChildren()) do
        if child:IsA("TextButton") then
            child.BackgroundTransparency = 1
            TweenService:Create(child, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {
                BackgroundTransparency = 0,
            }):Play()
            local stroke = child:FindFirstChildOfClass("UIStroke")
            if stroke then
                TweenService:Create(stroke, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {
                    Transparency = 1,
                }):Play()
            end
        end
    end

    task.wait(0.3)
    TweenService:Create(FooterNote, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {
        TextTransparency = 0,
    }):Play()

    -- ── Wait for choice ───────────────────────────────────────────────────────
    repeat task.wait(0.05) until chosen ~= nil

    -- ── Animate out ───────────────────────────────────────────────────────────
    TweenService:Create(Card, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 470, 0, 260),
    }):Play()
    TweenService:Create(ShadowImg, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {
        ImageTransparency = 1,
    }):Play()
    TweenService:Create(CardTopbar, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {
        BackgroundTransparency = 1,
    }):Play()
    TweenService:Create(CornerRepair, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {
        BackgroundTransparency = 1,
    }):Play()
    TweenService:Create(TopbarTitle, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {
        TextTransparency = 1,
    }):Play()
    TweenService:Create(Subtitle, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {
        TextTransparency = 1,
    }):Play()
    TweenService:Create(FooterNote, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {
        TextTransparency = 1,
    }):Play()
    TweenService:Create(Backdrop, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {
        BackgroundTransparency = 1,
    }):Play()

    task.wait(0.5)
    ChooserGui:Destroy()

    return chosen
end

