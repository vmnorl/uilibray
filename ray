-- THEME CHANGE  (safe — pcall every topbar child access)
-- ════════════════════════════════════════════════════════════════════════════════

local function ChangeTheme(ThemeName)
    SelectedTheme = RayfieldLibrary.Theme[ThemeName] or RayfieldLibrary.Theme.Default
    CurrentThemeName = ThemeName

    -- Text objects
    for _, obj in ipairs(Rayfield:GetDescendants()) do
        if obj.ClassName == "TextLabel" or obj.ClassName == "TextBox" or obj.ClassName == "TextButton" then
            if SelectedTheme.TextFont ~= "Default" then
                pcall(function()
                    obj.TextColor3 = SelectedTheme.TextColor
                    obj.Font = Enum.Font[SelectedTheme.TextFont]
                end)
            end
        end
    end

    -- Main frames
    pcall(function() Main.BackgroundColor3 = SelectedTheme.Background end)
    pcall(function() Main.Topbar.BackgroundColor3 = SelectedTheme.Topbar end)
    pcall(function() Main.Topbar.CornerRepair.BackgroundColor3 = SelectedTheme.Topbar end)
    pcall(function() Main.Shadow.Image.ImageColor3 = SelectedTheme.Shadow end)

    -- Topbar image buttons — safe iteration, no hardcoded names
    pcall(function()
        for _, btn in ipairs(Main.Topbar:GetChildren()) do
            if btn:IsA("ImageButton") then
                btn.ImageColor3 = SelectedTheme.TextColor
            end
        end
    end)

    -- Elements
    for _, TabPage in ipairs(Elements:GetChildren()) do
        for _, Element in ipairs(TabPage:GetChildren()) do
            if Element.ClassName == "Frame"
            and Element.Name ~= "Placeholder"
            and Element.Name ~= "SectionSpacing"
            and Element.Name ~= "SectionTitle" then
                pcall(function()
                    Element.BackgroundColor3 = SelectedTheme.ElementBackground
                    Element.UIStroke.Color   = SelectedTheme.ElementStroke
                end)
            end
        end
    end

    -- Rebuild HUD with updated colors
    createHUD()
end

