function RayfieldLibrary:CreateWindow(Settings)

    -- Show version chooser FIRST
    local chosenVersion = showVersionChooser()
    RayfieldLibrary.Version = chosenVersion
    print("[Rayfield] Version chosen: " .. chosenVersion)

    -- Apply initial theme safely
    local initialTheme = (Settings.DefaultTheme and RayfieldLibrary.Theme[Settings.DefaultTheme])
        and Settings.DefaultTheme or "Default"
    ChangeTheme(initialTheme)

    -- HUD
    if Settings.HUD ~= false then createHUD() end

    -- Config
    pcall(function()
        if Settings.ConfigurationSaving then
            CFileName = Settings.ConfigurationSaving.FileName or tostring(game.PlaceId)
            ConfigurationFolder = Settings.ConfigurationSaving.FolderName or ConfigurationFolder
            CEnabled = Settings.ConfigurationSaving.Enabled or false
            if CEnabled and not isfolder(ConfigurationFolder) then makefolder(ConfigurationFolder) end
        end
    end)

    AddDraggingFunctionality(Topbar, Main)

    Topbar.Title.Text = Settings.Name
    Main.Size = UDim2.new(0,450,0,260)
    Main.Visible = true
    Main.BackgroundTransparency = 1
    LoadingFrame.Title.TextTransparency = 1
    LoadingFrame.Subtitle.TextTransparency = 1
    Main.Shadow.Image.ImageTransparency = 1
    LoadingFrame.Version.TextTransparency = 1
    LoadingFrame.Title.Text   = Settings.LoadingTitle   or "Rayfield Interface Suite"
    LoadingFrame.Subtitle.Text = Settings.LoadingSubtitle or ("by Sirius  •  " .. chosenVersion)
    LoadingFrame.Version.Text  = Release
    Topbar.Visible    = false
    Elements.Visible  = false
    LoadingFrame.Visible = true

    for _, TabButton in ipairs(TabList:GetChildren()) do
        if TabButton.ClassName == "Frame" and TabButton.Name ~= "Placeholder" then
            TabButton.BackgroundTransparency = 1
            pcall(function() TabButton.Title.TextTransparency  = 1 end)
            pcall(function() TabButton.Shadow.ImageTransparency = 1 end)
            pcall(function() TabButton.Image.ImageTransparency  = 1 end)
            pcall(function() TabButton.UIStroke.Transparency    = 1 end)
